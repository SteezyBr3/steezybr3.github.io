---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";

const weddingImages = Array.from({ length: 16 }, (_, index) => ({
  src: `/weddings/wedding-${index + 1}.jpeg`,
  alt: `Wedding floral arrangement ${index + 1}`,
}));
---

<Layout
  title={`Weddings | ${SITE.title}`}
  description="Explore wedding florals, ceremony arrangements, and bridal bouquet inspiration."
  canonicalURL={`${SITE.url}/weddings`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-7xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold mb-4" style="color: var(--color-text);">Weddings</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <div class="max-w-5xl space-y-8 mb-14" style="color: var(--color-text-soft);">
          <p class="text-lg md:text-xl leading-8">
            S Bouquets offer bespoke wedding florals for couples in Kent and beyond. 
            Specialising in bespoke bridal bouquets and elegant arrangements, every design is hand-crafted using seasonal blooms to reflect your style, theme and love story. 
          </p>

          <p class="text-lg md:text-xl leading-8">
            We work closely with you to bring your vision to life - with a passion for quality and artistry, we ensure your wedding flowers feel unforgettable from the walk down the aisle to the final photograph. 
          </p>

          <p class="text-lg md:text-xl leading-8">
            From Bridal Bouquets and Buttonholes to Table centrepieces and arrangements we provide a bespoke service covering everything you need, every wedding flower arrangement is thoughtfully designed to reflect you. 
          </p>

          <p class="text-lg md:text-xl leading-8">
            Book your wedding consultation today and begin your floral journey with Samantha’s Bouquets.
          </p>
        </div>
      </ScrollReveal>

      <div class="gallery-masonry">
        {weddingImages.map((image, index) => (
          <ScrollReveal client:idle delay={Math.min(index * 0.025, 0.3)}>
            <div class="gallery-masonry-item">
              <figure>
                <img src={image.src} alt={image.alt} loading="lazy" />
              </figure>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
