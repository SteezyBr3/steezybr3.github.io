---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";

const weddingImages = Array.from({ length: 16 }, (_, index) => ({
  src: `/weddings/wedding-${index + 1}.jpeg`,
  alt: `Wedding floral arrangement ${index + 1}`,
}));
---

<Layout
  title={`Weddings | ${SITE.title}`}
  description="Explore wedding florals, ceremony arrangements, and bridal bouquet inspiration."
  canonicalURL={`${SITE.url}/weddings`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-7xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold mb-4" style="color: var(--color-text);">Weddings</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <div class="max-w-5xl mb-14" style="color: var(--color-text-soft);">
          <p class="text-lg md:text-xl leading-8">
            Your wedding flowers should be as unique and beautiful as your love story.
          </p>


          <p class="text-lg md:text-xl leading-8">
            At Samantha’s Bouquets, we specialise in creating luxurious, bespoke wedding florals designed to complement your style, venue, and vision.
            From stunning bridal bouquets and elegant bridesmaids’ flowers to breathtaking ceremony arrangements, table centrepieces, and floral installations, every design is thoughtfully handcrafted using the finest seasonal blooms.
            Whether you’re planning an intimate celebration or a grand wedding, we work closely with you to create unforgettable floral arrangements that bring your dream day to life.
          </p>

          <p class="text-lg md:text-xl leading-8">
            Based in Maidstone, Kent, we offer a personal, friendly service with attention to every detail, ensuring your wedding flowers are as memorable as the day itself.
            Let us transform your venue with beautiful flowers that capture the romance, elegance, and joy of your special day.
          </p>

          <p class="text-lg md:text-xl leading-8">
            Book your wedding consultation today and begin your floral journey with Samantha’s Bouquets.
          </p>
        </div>
      </ScrollReveal>

      <div class="gallery-masonry">
        {weddingImages.map((image, index) => (
          <ScrollReveal client:idle delay={Math.min(index * 0.025, 0.3)}>
            <div class="gallery-masonry-item">
              <figure>
                <img src={image.src} alt={image.alt} loading="lazy" />
              </figure>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
