---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Returns and Refunds | ${SITE.title}`}
  description="Information about returns, refunds, and order support."
  canonicalURL={`${SITE.url}/returns-and-refunds`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-4xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold mb-6" style="color: var(--color-text);">Returns and Refunds</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <div class="prose prose-lg max-w-none" style="color: var(--color-text-soft);">
          <p>
            We do NOT offer returns or refunds.
            Once your payment or deposit has been paid you are no longer eligible for a refund and your order will go ahead.
            (if you have paid a deposit but fail to make the reaming payment your order will be cancelled, the deposit is none refundable)
            All flower arrangements come with flower food and care instructions to increase the freshness of your flowers.
            Should there be a problem with your order, we require notification within 24 hours of delivery to allow us to investigate.
            A photograph will be required to support claims. Returns will be discussed
            All products require care and attention, if it is deemed that the products have not been cared for as per instructions on our flower care 
            cards then we may NOT offer a refund.
          </p>
          <p>
            Returns, refunds, partial refunds or an exchange will ONLY be an option and ONLY 
            be given if the product is proved to be faulty or damaged and will be at the discretion of management.
          </p>
        </div>
      </ScrollReveal>
    </section>
  </main>
  <Footer />
</Layout>
