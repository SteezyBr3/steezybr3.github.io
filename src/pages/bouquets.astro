---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";

const bouquetImages = Array.from({ length: 25 }, (_, index) => ({
  src: `/bouquets/bouquet-${index + 1}.jpg`,
  alt: `Bouquet arrangement ${index + 1}`,
}));
---

<Layout
  title={`Bouquets | ${SITE.title}`}
  description="Browse a collection of handcrafted bouquets for gifting, celebrations, and everyday floral styling."
  canonicalURL={`${SITE.url}/bouquets`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-6xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold mb-4" style="color: var(--color-text);">Bouquets</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <p class="text-lg md:text-xl max-w-3xl mb-12" style="color: var(--color-text-soft);">
          Add your bouquet page introduction here. This section is ready for your own wording about bouquet styles, ordering, gifting, or seasonal collections.
        </p>
      </ScrollReveal>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {bouquetImages.map((image, index) => (
          <ScrollReveal client:idle delay={Math.min(index * 0.03, 0.45)}>
            <figure
              class="overflow-hidden rounded-2xl border shadow-sm transition duration-300 hover:shadow-lg"
              style="background-color: var(--color-surface); border-color: var(--color-border);"
            >
              <img
                src={image.src}
                alt={image.alt}
                loading="lazy"
                class="aspect-square w-full object-cover transition duration-300 hover:scale-105"
              />
            </figure>
          </ScrollReveal>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
