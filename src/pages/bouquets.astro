---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";

const bouquetImages = Array.from({ length: 25 }, (_, index) => ({
  src: `/bouquets/bouquet-${index + 1}.jpeg`,
  alt: `Bouquet arrangement ${index + 1}`,
}));
---

<Layout
  title={`Bouquets | ${SITE.title}`}
  description="Browse a collection of handcrafted bouquets for gifting, celebrations, and everyday floral styling."
  canonicalURL={`${SITE.url}/bouquets`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-7xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold mb-4" style="color: var(--color-text);">Bouquets</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <div class="max-w-5xl space-y-8 mb-14" style="color: var(--color-text-soft);">
          <p class="text-lg md:text-xl leading-8">
            All of our floral arrangements are bespoke, meaning each design is unique and may vary slightly.
            We believe attention to detail is key and all of our designs are made with the freshest luxury flowers. Everything we create is made with love, care and attention.
          </p>

          <p class="text-lg md:text-xl leading-8">
            A fully qualified florist with a passion for affordable luxury. 
            Our Bouquets and Services are hand-picked, designed and carefully curated with a selection of fresh, vibrant, fragrant seasonal blooms available in a variety of styles and colours.
          </p>
        </div>
      </ScrollReveal>

      <div class="gallery-masonry">
        {bouquetImages.map((image, index) => (
          <ScrollReveal client:idle delay={Math.min(index * 0.02, 0.3)}>
            <div class="gallery-masonry-item">
              <figure>
                <img src={image.src} alt={image.alt} loading="lazy" />
              </figure>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
