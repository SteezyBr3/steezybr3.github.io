---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";

const bouquetImages = Array.from({ length: 25 }, (_, index) => ({
  src: `/bouquets/bouquet-${index + 1}.jpg`,
  alt: `Bouquet arrangement ${index + 1}`,
}));

const getSpanClass = (index: number) => {
  const pattern = [
    "editorial-span-lg",
    "editorial-span-md",
    "editorial-span-tall",
    "editorial-span-md",
    "editorial-span-wide",
    "editorial-span-md",
  ];

  return pattern[index % pattern.length];
};
---

<Layout
  title={`Bouquets | ${SITE.title}`}
  description="Browse a collection of handcrafted bouquets for gifting, celebrations, and everyday floral styling."
  canonicalURL={`${SITE.url}/bouquets`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-7xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold mb-4" style="color: var(--color-text);">Bouquets</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <div class="max-w-5xl space-y-8 mb-14" style="color: var(--color-text-soft);">
          <p class="text-lg md:text-xl leading-8">
            Please feel free to send us a message with any questions or enquiries.
            ALL orders are bespoke and there for each arrangement will always be slightly different.
            Please note if you are sending a picture of a design you are after we will follow the design as best we can however we cannot guarantee it will be an exact match.
            This is due to the stock available from season to season and what is available to order / what is available on the day.
            When placing your order we take full payment, unless a deposit has been agreed (deposits are NOT available on Shipping Orders)
            If a deposit has been taken the remaining balance will need to be paid before your Local Delivery is made or on / before Collection.
            (unless cash has been confirmed)
          </p>

          <p class="text-lg md:text-xl leading-8">
            Please note all of our bouquet orders are currently on a 48 hour turn around (this is dependent on seasons and other orders so is subject to change, if you need your arrangement within the 48 hour period or same day delivery please message us asap to see if we can book you in (an out of hours fee might be charged on your order)
            Our bespoke Bouquets and Services are designed and carefully curated with a selection of fresh, vibrant, and fragrant seasonal blooms. Our Luxury hand-picked arrangements are available in a variety of styles and colours.
          </p>
        </div>
      </ScrollReveal>

      <div class="editorial-gallery">
        {bouquetImages.map((image, index) => (
          <ScrollReveal client:idle delay={Math.min(index * 0.02, 0.35)}>
            <figure class={`editorial-card ${getSpanClass(index)}`}>
              <img
                src={image.src}
                alt={image.alt}
                loading="lazy"
              />
            </figure>
          </ScrollReveal>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
