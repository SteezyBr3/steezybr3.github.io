---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Contact | ${SITE.title}`}
  description="Get in touch to enquire about bouquets, weddings, and custom floral arrangements."
  canonicalURL={`${SITE.url}/contact`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-3xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold mb-4" style="color: var(--color-text);">Contact</h1>
      </ScrollReveal>
      <ScrollReveal client:idle delay={0.2}>
        <p class="text-xl mb-12" style="color: var(--color-text-soft);">
          Use the form below to ask about bouquet orders, wedding flowers, or any bespoke floral request.
        </p>
      </ScrollReveal>

      <ScrollReveal client:idle delay={0.3}>
        <div class="rounded-3xl border p-8 shadow-sm" style="background-color: var(--color-surface); border-color: var(--color-border);">
          <ContactForm />
        </div>
      </ScrollReveal>
    </section>
  </main>
  <Footer />
</Layout>
