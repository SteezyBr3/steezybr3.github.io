---
import { Icon } from "astro-icon/components";
import { SITE } from "../config/site.mjs";
---

<footer
  class="w-full py-12 px-4 border-t"
  style="background-color: var(--color-surface-strong); border-color: var(--color-border);"
  role="contentinfo"
>
  <div class="max-w-6xl mx-auto">
    <div class="grid gap-8 md:grid-cols-4 mb-8">
      <div>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text);">{SITE.title}</h2>
        <p style="color: var(--color-text-soft);">
          Bespoke Floral Design Based in Headcorn, Maidstone Kent. 
        </p>
      </div>
      <div>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text);">Browse</h2>
        <ul class="space-y-2">
          <li><a href="/bouquets" class="transition-colors" style="color: var(--color-text-soft);">Bouquets</a></li>
          <li><a href="/weddings" class="transition-colors" style="color: var(--color-text-soft);">Weddings</a></li>
          <li><a href="/contact" class="transition-colors" style="color: var(--color-text-soft);">Contact</a></li>
        </ul>
      </div>
      <div>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text);">Information</h2>
        <ul class="space-y-2">
          <li>
            <a href="/returns-and-refunds" class="transition-colors" style="color: var(--color-text-soft);">
              Returns and Refunds
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="flex items-center gap-2 transition-colors"
              style="color: var(--color-text-soft);"
            >
              <Icon name="tabler:mail" class="w-5 h-5" aria-hidden="true" />
              <span>Email Us</span>
            </a>
          </li>
        </ul>
      </div>
      <div>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text);">Opening Hours</h2>
        <ul class="space-y-2" style="color: var(--color-text-soft);">
          <li>Monday - Saturday: 9am - 3pm</li>
          <li>Sunday: Pre-Booked ONLY</li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t text-center" style="border-color: var(--color-border); color: var(--color-text-soft);">
      <p>&copy; {new Date().getFullYear()} {SITE.title}. All rights reserved.</p>
    </div>
  </div>
</footer>
