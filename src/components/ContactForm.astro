---
import { SITE } from "../config/site.mjs";

const accessKey = SITE.web3formsAccessKey || "";
---

{!accessKey ? (
  <div class="rounded-xl border border-yellow-300 bg-yellow-50 p-4 text-sm text-yellow-900">
    <p><strong>Web3Forms not configured</strong></p>
    <p>
      Please add your Web3Forms access key to <code>src/config/site.mjs</code>.
    </p>
  </div>
) : (
  <form
    action="https://api.web3forms.com/submit"
    method="POST"
    class="space-y-6"
  >
    <input type="hidden" name="access_key" value={accessKey} />
    <input type="hidden" name="subject" value="New contact form submission" />
    <input type="hidden" name="from_name" value="Florist Website" />

    <div>
      <label for="name" class="mb-2 block font-medium">Name *</label>
      <input
        id="name"
        name="name"
        type="text"
        required
        class="w-full rounded-lg border border-gray-300 px-4 py-3"
      />
    </div>

    <div>
      <label for="email" class="mb-2 block font-medium">Email *</label>
      <input
        id="email"
        name="email"
        type="email"
        required
        class="w-full rounded-lg border border-gray-300 px-4 py-3"
      />
    </div>

    <div>
      <label for="message" class="mb-2 block font-medium">Message *</label>
      <textarea
        id="message"
        name="message"
        rows="6"
        required
        class="w-full rounded-lg border border-gray-300 px-4 py-3"
      ></textarea>
    </div>

    <button
      type="submit"
      class="rounded-lg bg-black px-6 py-3 text-white"
    >
      Send Message
    </button>
  </form>
)}