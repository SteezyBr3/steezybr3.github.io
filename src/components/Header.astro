---
import { Icon } from "astro-icon/components";
---

<header
  class="w-full py-4 px-4 sticky top-0 z-50 border-b"
  style="background-color: var(--color-header); border-color: var(--color-border);"
  role="banner"
>
  <nav
    class="max-w-6xl mx-auto flex items-center justify-between gap-6"
    aria-label="Main navigation"
  >
    <a href="/" class="inline-flex items-center" aria-label="SXBouquet's - Home">
      <img
        src="/logo.png"
        alt="Samantha's Flowers"
        class="h-14 w-auto object-contain"
      />
    </a>

    <button
      type="button"
      class="md:hidden p-2 rounded-lg"
      style="color: var(--color-text);"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="mobile-menu-button"
    >
      <Icon name="tabler:menu-2" class="w-6 h-6" aria-hidden="true" />
    </button>

    <ul class="hidden md:flex items-center gap-6" role="list">
      <li>
        <a
          href="/bouquets"
          class="transition-colors"
          style="color: var(--color-text);"
          aria-current={Astro.url.pathname === '/bouquets' ? 'page' : undefined}
        >
          Bouquets
        </a>
      </li>
      <li>
        <a
          href="/weddings"
          class="transition-colors"
          style="color: var(--color-text);"
          aria-current={Astro.url.pathname === '/weddings' ? 'page' : undefined}
        >
          Weddings
        </a>
      </li>
      <li>
        <a
          href="/contact"
          class="px-4 py-2 rounded-lg transition-colors"
          style="background-color: var(--color-accent); color: white;"
          aria-current={Astro.url.pathname === '/contact' ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
    </ul>
  </nav>

  <div
    id="mobile-menu"
    class="hidden md:hidden border-t mt-4"
    style="border-color: var(--color-border); background-color: var(--color-header);"
    role="menu"
    aria-labelledby="mobile-menu-button"
  >
    <ul class="flex flex-col py-2" role="list">
      <li>
        <a
          href="/bouquets"
          class="block px-4 py-3 transition-colors"
          style="color: var(--color-text);"
          role="menuitem"
          aria-current={Astro.url.pathname === '/bouquets' ? 'page' : undefined}
        >
          Bouquets
        </a>
      </li>
      <li>
        <a
          href="/weddings"
          class="block px-4 py-3 transition-colors"
          style="color: var(--color-text);"
          role="menuitem"
          aria-current={Astro.url.pathname === '/weddings' ? 'page' : undefined}
        >
          Weddings
        </a>
      </li>
      <li>
        <a
          href="/contact"
          class="block px-4 py-3 transition-colors"
          style="color: var(--color-text);"
          role="menuitem"
          aria-current={Astro.url.pathname === '/contact' ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuButton && mobileMenu) {
    menuButton.addEventListener('click', () => {
      const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
    });

    document.addEventListener('click', (e) => {
      if (
        !menuButton.contains(e.target as Node) &&
        !mobileMenu.contains(e.target as Node) &&
        !mobileMenu.classList.contains('hidden')
      ) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
        menuButton.focus();
      }
    });
  }
</script>
